install_target: first FORCE
	@test -d C:$(INSTALL_ROOT:@msyshack@%=%)/Dev/Qt/Examples/Qt-6.9.0/widgets/tutorials/notepad || mkdir -p C:$(INSTALL_ROOT:@msyshack@%=%)/Dev/Qt/Examples/Qt-6.9.0/widgets/tutorials/notepad
	-$(INSTALL_FILE) $(DESTDIR_TARGET) C:$(INSTALL_ROOT:@msyshack@%=%)/Dev/Qt/Examples/Qt-6.9.0/widgets/tutorials/notepad/$(TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) C:$(INSTALL_ROOT:@msyshack@%=%)/Dev/Qt/Examples/Qt-6.9.0/widgets/tutorials/notepad/$(TARGET)
	-$(DEL_DIR) C:$(INSTALL_ROOT:@msyshack@%=%)/Dev/Qt/Examples/Qt-6.9.0/widgets/tutorials/notepad/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

