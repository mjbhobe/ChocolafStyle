compiler_clean: compiler_rcc_clean compiler_moc_predefs_clean compiler_moc_header_clean 



####### Compile

build/release/.obj/main.o: main.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/release/.obj/main.o main.cpp

build/release/.obj/qrc_chocolaf.o: build/release/.qrc/qrc_chocolaf.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/release/.obj/qrc_chocolaf.o build/release/.qrc/qrc_chocolaf.cpp

build/release/.obj/qrc_QtAwesomeFree.o: build/release/.qrc/qrc_QtAwesomeFree.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/release/.obj/qrc_QtAwesomeFree.o build/release/.qrc/qrc_QtAwesomeFree.cpp

build/release/.obj/moc_QtAwesome.o: build/release/.moc/moc_QtAwesome.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/release/.obj/moc_QtAwesome.o build/release/.moc/moc_QtAwesome.cpp

build/release/.obj/moc_QtAwesomeAnim.o: build/release/.moc/moc_QtAwesomeAnim.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o build/release/.obj/moc_QtAwesomeAnim.o build/release/.moc/moc_QtAwesomeAnim.cpp

####### Install

install_target: first FORCE
	@test -d C:$(INSTALL_ROOT:@msyshack@%=%)/Dev/msys64/mingw64/examples/widgets/tutorials/gettingStarted/gsQt/part1 || mkdir -p C:$(INSTALL_ROOT:@msyshack@%=%)/Dev/msys64/mingw64/examples/widgets/tutorials/gettingStarted/gsQt/part1
	-$(INSTALL_FILE) $(DESTDIR_TARGET) C:$(INSTALL_ROOT:@msyshack@%=%)/Dev/msys64/mingw64/examples/widgets/tutorials/gettingStarted/gsQt/part1/$(TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) C:$(INSTALL_ROOT:@msyshack@%=%)/Dev/msys64/mingw64/examples/widgets/tutorials/gettingStarted/gsQt/part1/$(TARGET)
	-$(DEL_DIR) C:$(INSTALL_ROOT:@msyshack@%=%)/Dev/msys64/mingw64/examples/widgets/tutorials/gettingStarted/gsQt/part1/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

.SUFFIXES:

